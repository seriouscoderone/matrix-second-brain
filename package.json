{
  "name": "matrix-second-brain",
  "version": "1.0.0",
  "description": "Matrix bot that turns a Matrix Space into a personal Second Brain",
  "main": "dist/bot/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/bot/index.js",
    "dev": "ts-node src/bot/index.ts",
    "test": "jest --testPathPattern='src/__tests__/unit'",
    "test:integration": "jest --testPathPattern='src/__tests__/integration' --runInBand",
    "test:location": "ts-node scripts/test-location.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "ts-node src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.0",
    "js-yaml": "^4.1.0",
    "matrix-bot-sdk": "^0.7.1",
    "node-cron": "^3.0.3",
    "pg": "^8.13.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
