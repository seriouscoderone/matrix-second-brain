# ============================================================
# Matrix Second Brain — Environment Variables
# Copy to .env (production) or .env.dev (local dev) and fill in values.
# NEVER commit .env to git.
# ============================================================

# --- Matrix ---
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_BOT_USER_ID=@secondbrain:example.com
MATRIX_BOT_ACCESS_TOKEN=syt_xxxxxxxxxxxxxxxxxxxx
ADMIN_MATRIX_ID=@alice:example.com

# --- Database ---
DATABASE_URL=postgresql://user:pass@localhost:5432/secondbrain

# --- LLM Provider ---
# Options: bedrock | anthropic | mock
LLM_PROVIDER=bedrock

# AWS Bedrock (required when LLM_PROVIDER=bedrock)
# Running on EC2 — credentials come from the instance profile (no keys needed here)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251001-v2:0

# Direct Anthropic API (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# --- Appservice Mode (optional) ---
# Set APPSERVICE_REGISTRATION to enable appservice mode (recommended for production).
# If not set, the bot uses client-server API mode (polls /sync — fine for dev).
# Generate registration.yaml with: npx ts-node scripts/generate-registration.ts
# APPSERVICE_REGISTRATION=/app/registration.yaml
# APPSERVICE_PORT=9090
# APPSERVICE_BIND_ADDRESS=0.0.0.0
# MATRIX_HOMESERVER_NAME=example.com

# --- Optional Tuning ---
# Minimum confidence score before bot asks clarifying questions (0.0–1.0)
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7
# Proximity alert radius in meters
ALERT_RADIUS_METERS=500
# Cooldown between location alerts per user per place (minutes)
LOCATION_COOLDOWN_MINUTES=120
